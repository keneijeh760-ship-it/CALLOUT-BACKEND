# Copy this file to .env and fill in your values
# NEVER commit .env to Git — it contains secrets
# .env.example is safe to commit — it has no real values

# Database
DATABASE_URL=jdbc:postgresql://localhost:5432/callout_dev
DATABASE_USERNAME=callout
DATABASE_PASSWORD=callout_secret

# Supabase
SUPABASE_JWKS_URI=https://your-project.supabase.co/auth/v1/keys

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# AWS
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
S3_BUCKET_NAME=callout-dev-attachments
SQS_INCIDENT_SUBMITTED_QUEUE=https://sqs.eu-west-1.amazonaws.com/...
SQS_NOTIFICATION_QUEUE=https://sqs.eu-west-1.amazonaws.com/...
SQS_ARCHIVAL_QUEUE=https://sqs.eu-west-1.amazonaws.com/...
SES_FROM_EMAIL=noreply@callout.app

# App
ALLOWED_DOMAIN=pau.edu.ng

